{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "incremental": true,
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "allowJs": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "types": ["@cloudflare/vitest-pool-workers", "@cloudflare/vitest-pool-workers/types"]
  },
  "include": [
    "worker-configuration.d.ts",
    "src",
    "web",
    "lib",
    "test"
  ],
  "exclude": [
    "node_modules"
  ]
}
