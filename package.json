{
  "name": "show-remind",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test": "vitest run --config vitest.config.mts && vitest run --config vitest.web.config.ts",
    "test:watch": "vitest",
    "web:dev": "vite",
    "web:build": "vite build",
    "test:web": "vitest run --config vitest.web.config.ts",
    "cf:dev": "wrangler dev",
    "cf:deploy": "npm run web:build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply show-remind --local",
    "db:migrate:remote": "wrangler d1 migrations apply show-remind --remote"
  },
  "dependencies": {
    "hono": "^4.12.30",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.4",
    "@cloudflare/workers-types": "^5.20260713.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "happy-dom": "^20.10.6",
    "tsx": "^4.23.0",
    "typescript": "^5.7.0",
    "vite": "^7.3.6",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
